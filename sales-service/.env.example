APP_NAME="Sales Service"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=db-sales
DB_PORT=5432
DB_DATABASE=sales
DB_USERNAME=sales
DB_PASSWORD=sales

CACHE_STORE=redis
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PORT=6379

CATALOG_API_URL=http://catalog-api:8000
INTERNAL_API_KEY=dev-internal-key

RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

FILA_LIBERACAO_VAGAS=500
PAGAMENTO_MOCK_FALHA=false
